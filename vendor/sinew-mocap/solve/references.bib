% --- Normal gravity (accel-channel normalization) -----------------------------
% Theoretical gravity on the reference ellipsoid varies with latitude, so the IMU accel
% magnitude carries a study-location systematic; the ACCA calibration cue is the gravity
% DIRECTION, motivating per-vector unit-normalization (slangtrain/torch/train_tic.py SINEW_ACCEL=grav).
@article{moritz1980grs80,
  author  = {Moritz, Helmut},
  title   = {Geodetic Reference System 1980},
  journal = {Bulletin G\'eod\'esique},
  year    = {1980},
  volume  = {54},
  number  = {3},
  pages   = {395--405},
  doi     = {10.1007/BF02521480},
  note    = {The closed-form normal-gravity formula on the GRS80 ellipsoid: theoretical gravity runs from 9.7803 m/s^2 at the equator to 9.8322 at the poles (~0.5\% range, ~0.3\% about the 9.81 mean), a per-location systematic in the accelerometer magnitude that carries no sensor-to-bone calibration signal — only the gravity direction (rotated by drift) does, so the accel channel is unit-normalized.}
}

% --- Training data source (the real normal-motion corpus) ---------------------
% AddBiomechanics aggregates many independent OpenSim-fit studies (Carter2023, Han2023,
% Tiziana2019, Moore2015, …); their per-study capture differences (marker protocol, frame
% rate, capture location → local g) are the cross-study domain shift the calibrator must cross.
% The windowed calibration parquets here are extracted from it by slangtrain/addb/b3d_to_caldata.py.
@inproceedings{werling2024addbiomechanics,
  author        = {Werling, Keenon and Kaneda, Janelle and others},
  title         = {{AddBiomechanics} Dataset: Capturing the Physics of Human Motion at Scale},
  booktitle     = {Computer Vision -- ECCV 2024},
  year          = {2024},
  eprint        = {2406.18537},
  archivePrefix = {arXiv},
  primaryClass  = {cs.CV},
  doi           = {10.1007/978-3-031-73223-2_27},
  url           = {https://arxiv.org/abs/2406.18537},
  note          = {273 subjects, 70+ hours, 24M frames of OpenSim-fit human motion + force-plate data aggregated from many independent studies (Carter2023, Han2023, Tiziana2019, Moore2015, …). Their per-study capture conventions (markers, frame rate, location → local g) differ, which is the cross-study domain shift the sensor-to-bone calibrator must generalise across.}
}

% Cyclic motion alignment via a learned phase manifold.  Relevant two ways: (1) cycle-aligned
% calibration windows — a window spanning one normalized gait cycle (vs an arbitrary 32-frame slice)
% contains the full motion range, maximising sensor-to-bone mount observability and lowering the
% per-window floor; (2) retargeting real motion onto ANNY phenotypes in the synthetic generator without
% paired data.  (Author list / DOI from the project page; verify before camera-ready.)
@inproceedings{li2024walkthedog,
  author    = {Li, Peizhuo and Starke, Sebastian and Ye, Yuting and Sorkine-Hornung, Olga},
  title     = {{WalkTheDog}: Cross-Morphology Motion Alignment via Phase Manifolds},
  booktitle = {ACM SIGGRAPH 2024 Conference Papers},
  year      = {2024},
  doi       = {10.1145/3641519.3658304},
  url       = {https://peizhuoli.github.io/walk-the-dog/},
  note      = {Aligns the cyclic/periodic structure of motion across morphologies (e.g. human and dog) through a shared phase manifold, enabling motion matching without paired data. Here: defines cycle-aligned (phase-normalized) calibration windows that carry the full per-cycle motion — more mount observability per window than a fixed 32-frame slice — and supports cross-phenotype motion retargeting for the synthetic generator.}
}
