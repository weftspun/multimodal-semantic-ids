% --- Continuous rotation representation & kinematics ---------------------------
% Backs the C⁴ Hermite rotation interpolation (spec/Sinew/Nonic.lean):
% interpolate a continuous rotation representation, not quaternions, and recover
% angular velocity/acceleration/jerk by the cross-product (hat/vee) map.

@inproceedings{zhou2019continuity,
  author    = {Zhou, Yi and Barnes, Connelly and Lu, Jingwan and Yang, Jimei and Li, Hao},
  title     = {On the Continuity of Rotation Representations in Neural Networks},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  year      = {2019},
  pages     = {5745--5753},
  doi       = {10.1109/CVPR.2019.00589},
  note      = {The 6D rotation representation: two 3-vectors mapped to SO(3) by Gram-Schmidt + cross product, continuous and surjective. Quaternions double-cover SO(3) and are discontinuous, so kinematics are computed in 6D rather than narrowing to quaternions.}
}

@book{murray1994robotic,
  author    = {Murray, Richard M. and Li, Zexiang and Sastry, S. Shankar},
  title     = {A Mathematical Introduction to Robotic Manipulation},
  publisher = {CRC Press},
  year      = {1994},
  isbn      = {9780849379819},
  note      = {The so(3) hat/vee isomorphism with the cross product: angular velocity omega = (Rdot R^T)^vee recovers the kinematic vector from the rotation-matrix derivative — how the Hermite-interpolated rotation curve yields angular velocity/acceleration/jerk.}
}

% --- Joint orientation / bone roll convention --------------------------------
% The canonical per-bone local frame the retarget adopts (spec/Sinew/RigRest.lean,
% spec/PlayLog.lean): local +Y runs along the bone toward the child, local +X is the
% bend axis (positive-X rotation bends/kicks forward), +Z completes the right-handed
% frame; arms are mirrored and legs' +Y points down.

@misc{labrcsf2026,
  author       = {Nick Porcino},
  title        = {{LabRCSF}: A Rig and Character Skeleton Format proposal},
  year         = {2026},
  howpublished = {\url{https://github.com/meshula/LabRCSF}},
  note         = {Joint-orientation convention: local +Y along the bone toward the child, local +X the primary bend axis (positive-X bends forward), +Z right-handed; spine axes align with world in neutral, legs' +Y points down, left/right arms mirrored. The retarget re-bone-rolls to this.}
}

