--
-- Lean-emitted Slang compute kernel for the per-frame mesh deform: linear-blend
-- skinning, the same math as the exported soma_lbs.onnx
--   out[v] = Σ_j w[v,j] · (R_j · bind[v] + t_j),  bone_j = world_j · invbind_j.
-- The host precomputes each joint's affine bone_j (3×4 = [R|t]) from cheap FK and
-- the constant inverse-bind; the kernel runs one thread per vertex.  Slang
-- compiles this one source to SPIR-V / Metal / DXIL (GPU) and a CPU host backend,
-- so Mac / Windows / Linux share one deform with no ONNX runtime and no Python.

namespace Sinew.SlangCodegen.Lbs

/-- Compute-kernel parameters. -/
structure Config where
  entry : String := "lbs"
  workgroup : Nat := 64
  deriving Repr

/-- Buffer declarations.  Explicit Vulkan set/bindings give the host a fixed
    descriptor layout; vertex and joint counts come from the buffer sizes, so no
    scalar uniforms (push constants / UBO) are needed. -/
private def decls : String :=
  "// AUTO-GENERATED by Sinew.SlangCodegen.Lbs — edit the Lean emitter, not this file.\n" ++
  "// Linear-blend skinning, one thread per vertex.  Matches soma_lbs.onnx:\n" ++
  "//   out[v] = sum_j w[v,j] * (R_j * bind[v] + t_j),  bone_j = world_j * invbind_j.\n\n" ++
  "[[vk::binding(0, 0)]] StructuredBuffer<float3> bind;     // (V)    rest vertices (constant)\n" ++
  "[[vk::binding(1, 0)]] StructuredBuffer<float>  weights;  // (V*J)  row-major weights (constant)\n" ++
  "[[vk::binding(2, 0)]] StructuredBuffer<float4> bone;     // (J*3)  per-joint affine [R|t]\n" ++
  "[[vk::binding(3, 0)]] RWStructuredBuffer<float3> verts;  // (V)    output\n\n"

/-- Kernel body (the per-vertex weighted blend). -/
private def kernelBody : String :=
  "{\n" ++
  "    uint v = tid.x;\n" ++
  "    uint vcount, vstride;\n" ++
  "    bind.GetDimensions(vcount, vstride);\n" ++
  "    if (v >= vcount) return;\n" ++
  "    uint bcount, bstride;\n" ++
  "    bone.GetDimensions(bcount, bstride);\n" ++
  "    uint jointCount = bcount / 3;\n" ++
  "    float3 bv = bind[v];\n" ++
  "    float3 acc = float3(0.0);\n" ++
  "    uint wbase = v * jointCount;\n" ++
  "    for (uint j = 0; j < jointCount; ++j)\n" ++
  "    {\n" ++
  "        float w = weights[wbase + j];\n" ++
  "        if (w == 0.0) continue;\n" ++
  "        uint b = j * 3;\n" ++
  "        float4 r0 = bone[b + 0];\n" ++
  "        float4 r1 = bone[b + 1];\n" ++
  "        float4 r2 = bone[b + 2];\n" ++
  "        float3 p = float3(\n" ++
  "            r0.x * bv.x + r0.y * bv.y + r0.z * bv.z + r0.w,\n" ++
  "            r1.x * bv.x + r1.y * bv.y + r1.z * bv.z + r1.w,\n" ++
  "            r2.x * bv.x + r2.y * bv.y + r2.z * bv.z + r2.w);\n" ++
  "        acc += w * p;\n" ++
  "    }\n" ++
  "    verts[v] = acc;\n" ++
  "}\n"

/-- The full Slang source for the LBS deform kernel. -/
def shader (cfg : Config := {}) : String :=
  decls ++
  "[shader(\"compute\")]\n" ++
  "[numthreads(" ++ toString cfg.workgroup ++ ", 1, 1)]\n" ++
  "void " ++ cfg.entry ++ "(uint3 tid : SV_DispatchThreadID)\n" ++
  kernelBody

end Sinew.SlangCodegen.Lbs
