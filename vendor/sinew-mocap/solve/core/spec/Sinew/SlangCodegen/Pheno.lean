--
-- Lean-emitted Slang compute kernels for the phenotype → body-shape pipeline (the
-- data-parallel stages; the tiny coefficient calc and the sequential per-joint
-- align_vectors fit stay host-side).  Same math as the verified reference in
-- viz_native/soma_pheno.c.  Slang compiles one source to SPIR-V / Metal / DXIL and
-- a CPU backend, so the body reshapes from the 11-dim phenotype with no ONNX
-- runtime and no Python.  Three kernels:
--   blendshape — v_anny[p] = template[p] + Σ_c coeffs[c] · blend[c·P + p]  (per vertex)
--   bary_tet   — p3[f] = a + (b−a)×(c−a)  for each source triangle          (per face)
--   bary_gather— v0[v]  = Σ_k bary[v,k] · Vtet[F_tet[face[v],k]], axis-remap (per vertex)
--   rbf        — Jpos[i]= Σ_{crow[i]≤k<crow[i+1]} val[k] · v0[col[k]]        (per joint)

namespace Sinew.SlangCodegen.Pheno

/-- Compute-kernel parameters. -/
structure Config where
  workgroup : Nat := 64
  deriving Repr

private def header : String :=
  "// AUTO-GENERATED by Sinew.SlangCodegen.Pheno — edit the Lean emitter, not this file.\n" ++
  "// Phenotype → shape, data-parallel stages.  Matches viz_native/soma_pheno.c.\n\n"

private def attr (cfg : Config) (entry : String) : String :=
  "[shader(\"compute\")]\n[numthreads(" ++ toString cfg.workgroup ++ ", 1, 1)]\n" ++
  "void " ++ entry ++ "(uint3 tid : SV_DispatchThreadID)\n"

/-- Blendshape GEMV: one thread per Anny vertex. -/
def blendshape (cfg : Config := {}) : String :=
  header ++
  "[[vk::binding(0, 0)]] StructuredBuffer<float3> templ;   // (P)    template verts\n" ++
  "[[vk::binding(1, 0)]] StructuredBuffer<float3> blend;   // (NB*P) blendshapes, row c*P+p\n" ++
  "[[vk::binding(2, 0)]] StructuredBuffer<float>  coeffs;  // (NB)   phenotype coeffs\n" ++
  "[[vk::binding(3, 0)]] RWStructuredBuffer<float3> vanny; // (P)    output\n\n" ++
  attr cfg "blendshape" ++
  "{\n" ++
  "    uint p = tid.x;\n" ++
  "    uint P, s; templ.GetDimensions(P, s);\n" ++
  "    if (p >= P) return;\n" ++
  "    uint NB, s2; coeffs.GetDimensions(NB, s2);\n" ++
  "    float3 acc = templ[p];\n" ++
  "    for (uint c = 0; c < NB; ++c)\n" ++
  "    {\n" ++
  "        float w = coeffs[c];\n" ++
  "        if (w == 0.0) continue;\n" ++
  "        acc += w * blend[c * P + p];\n" ++
  "    }\n" ++
  "    vanny[p] = acc;\n" ++
  "}\n"

/-- Fabricate each source triangle's normal-tip tet vertex: one thread per face. -/
def baryTet (cfg : Config := {}) : String :=
  header ++
  "[[vk::binding(0, 0)]] StructuredBuffer<float3> vanny;  // (P)     Anny verts\n" ++
  "[[vk::binding(1, 0)]] StructuredBuffer<uint>   Fsrc;   // (NFS*3) source tri indices\n" ++
  "[[vk::binding(2, 0)]] RWStructuredBuffer<float3> p3;   // (NFS)   output tip\n\n" ++
  attr cfg "bary_tet" ++
  "{\n" ++
  "    uint f = tid.x;\n" ++
  "    uint NFS, s; p3.GetDimensions(NFS, s);\n" ++
  "    if (f >= NFS) return;\n" ++
  "    float3 a = vanny[Fsrc[f * 3 + 0]];\n" ++
  "    float3 b = vanny[Fsrc[f * 3 + 1]];\n" ++
  "    float3 c = vanny[Fsrc[f * 3 + 2]];\n" ++
  "    p3[f] = a + cross(b - a, c - a);\n" ++
  "}\n"

/-- Barycentric transfer Anny→SOMA + axis remap (x,y,z)_soma = (x, z, −y)_anny:
    one thread per SOMA vertex. -/
def baryGather (cfg : Config := {}) : String :=
  header ++
  "[[vk::binding(0, 0)]] StructuredBuffer<float3> vanny;  // (P)     Anny verts\n" ++
  "[[vk::binding(1, 0)]] StructuredBuffer<float3> p3;     // (NFS)   fabricated tips\n" ++
  "[[vk::binding(2, 0)]] StructuredBuffer<uint>   Ftet;   // (NFS*4) tet indices into [vanny|p3]\n" ++
  "[[vk::binding(3, 0)]] StructuredBuffer<uint>   fids;   // (V)     source face per vertex\n" ++
  "[[vk::binding(4, 0)]] StructuredBuffer<float>  bary;   // (V*4)   barycentric weights\n" ++
  "[[vk::binding(5, 0)]] RWStructuredBuffer<float3> v0;   // (V)     output (SOMA frame)\n\n" ++
  attr cfg "bary_gather" ++
  "{\n" ++
  "    uint v = tid.x;\n" ++
  "    uint V, s; v0.GetDimensions(V, s);\n" ++
  "    if (v >= V) return;\n" ++
  "    uint P, s2; vanny.GetDimensions(P, s2);\n" ++
  "    uint f = fids[v];\n" ++
  "    float3 r = float3(0.0);\n" ++
  "    for (uint k = 0; k < 4; ++k)\n" ++
  "    {\n" ++
  "        uint idx = Ftet[f * 4 + k];\n" ++
  "        float3 pt = (idx < P) ? vanny[idx] : p3[idx - P];\n" ++
  "        r += bary[v * 4 + k] * pt;\n" ++
  "    }\n" ++
  "    v0[v] = float3(r.x, r.z, -r.y);\n" ++
  "}\n"

/-- Skeleton rotation fit (the sequential `align_vectors` pass) as a single-thread
    kernel: one invocation runs the whole per-joint loop because joint i's world
    rotation depends on its parent's.  Direct transcription of the verified C in
    viz_native/soma_pheno.c (Rodrigues for N=1; else virtual-normal covariance →
    reference regularize → Newton-Schulz×30 → validity check → Jacobi-SVD Kabsch
    fallback).  Writes the new bind world transforms (rotation from the fit,
    translation from the regressed joint positions). -/
def skeletonFit : String :=
  header ++
  "[[vk::binding(0, 0)]] StructuredBuffer<float>  v0;      // (V*3) rest verts\n" ++
  "[[vk::binding(1, 0)]] StructuredBuffer<float>  bsh;     // (V*3) base bind shape\n" ++
  "[[vk::binding(2, 0)]] StructuredBuffer<float>  bw;      // (J*16) base bind world (R0 + base joint pos)\n" ++
  "[[vk::binding(3, 0)]] StructuredBuffer<float>  jpos;    // (J*3) regressed joint positions\n" ++
  "[[vk::binding(4, 0)]] StructuredBuffer<float>  sw;      // (V*J) skinning weights\n" ++
  "[[vk::binding(5, 0)]] StructuredBuffer<int>    parents; // (J)\n" ++
  "[[vk::binding(6, 0)]] RWStructuredBuffer<float> outbw;  // (J*16) output bind world\n\n" ++
  "static const float EPS = 1e-8;\n\n" ++
  "float3 cr(float3 a, float3 b) { return float3(a.y*b.z-a.z*b.y, a.z*b.x-a.x*b.z, a.x*b.y-a.y*b.x); }\n" ++
  "float det9(float m[9]) { return m[0]*(m[4]*m[8]-m[5]*m[7]) - m[1]*(m[3]*m[8]-m[5]*m[6]) + m[2]*(m[3]*m[7]-m[4]*m[6]); }\n" ++
  "void mul9(float A[9], float B[9], out float C[9]) {\n" ++
  "    for (int r = 0; r < 3; r++) for (int c = 0; c < 3; c++)\n" ++
  "        C[r*3+c] = A[r*3]*B[c] + A[r*3+1]*B[3+c] + A[r*3+2]*B[6+c];\n}\n" ++
  "void rodrigues(float3 a, float3 b, out float R[9]) {\n" ++
  "    float an = length(a), bn = length(b);\n" ++
  "    float3 au = a/max(an,EPS), bu = b/max(bn,EPS);\n" ++
  "    float d = clamp(dot(au,bu), -1.0, 1.0);\n" ++
  "    if (d < -1.0 + 1e-6) {\n" ++
  "        float3 w = (abs(bu.x) > 0.6) ? float3(0,1,0) : float3(1,0,0);\n" ++
  "        float3 x = cr(bu,w); x = x/length(x); float aa[3] = {x.x,x.y,x.z};\n" ++
  "        for (int r = 0; r < 3; r++) for (int c = 0; c < 3; c++) R[r*3+c] = 2.0*aa[r]*aa[c] - ((r==c)?1.0:0.0);\n" ++
  "        return;\n    }\n" ++
  "    float3 v = cr(bu,au);\n" ++
  "    float K[9]; K[0]=0; K[1]=-v.z; K[2]=v.y; K[3]=v.z; K[4]=0; K[5]=-v.x; K[6]=-v.y; K[7]=v.x; K[8]=0;\n" ++
  "    float KK[9]; mul9(K,K,KK); float f = 1.0/(1.0+d);\n" ++
  "    for (int i = 0; i < 9; i++) R[i] = ((i%4==0)?1.0:0.0) + K[i] + f*KK[i];\n}\n" ++
  "void ns30(float H[9], out float R[9]) {\n" ++
  "    float mrs = 0;\n" ++
  "    for (int r = 0; r < 3; r++) { float s = abs(H[r*3])+abs(H[r*3+1])+abs(H[r*3+2]); mrs = max(mrs,s); }\n" ++
  "    for (int i = 0; i < 9; i++) R[i] = H[i]/(mrs+EPS);\n" ++
  "    for (int it = 0; it < 30; it++) {\n" ++
  "        float RtR[9];\n" ++
  "        for (int a = 0; a < 3; a++) for (int b = 0; b < 3; b++) RtR[a*3+b] = R[a]*R[b]+R[3+a]*R[3+b]+R[6+a]*R[6+b];\n" ++
  "        float term[9]; for (int k = 0; k < 9; k++) term[k] = ((k%4==0)?3.0:0.0) - RtR[k];\n" ++
  "        float Rn[9]; mul9(R,term,Rn); for (int k = 0; k < 9; k++) R[k] = Rn[k]*0.5;\n    }\n" ++
  "    if (det9(R) < 0) { R[2]=-R[2]; R[5]=-R[5]; R[8]=-R[8]; }\n}\n" ++
  "void regularize(inout float H[9]) {\n" ++
  "    float scale = 0;\n" ++
  "    for (int r = 0; r < 3; r++) { float s = abs(H[r*3])+abs(H[r*3+1])+abs(H[r*3+2]); scale = max(scale,s); }\n" ++
  "    if (scale < EPS) scale = EPS;\n" ++
  "    float vol = abs(det9(H))/(scale*scale*scale);\n" ++
  "    float rw = clamp((1e-6 - vol)/1e-6, 0.0, 1.0); float add = 0.05*rw*scale;\n" ++
  "    H[0]+=add; H[4]+=add; H[8]+=add;\n}\n" ++
  "bool valid9(float R[9]) {\n" ++
  "    float d = det9(R);\n" ++
  "    if (!(d > 0.0 && abs(d-1.0) <= 1e-2)) return false;\n" ++
  "    float e = 0;\n" ++
  "    for (int i = 0; i < 3; i++) for (int j = 0; j < 3; j++) { float v = R[i]*R[j]+R[3+i]*R[3+j]+R[6+i]*R[6+j]-((i==j)?1.0:0.0); e = max(e,abs(v)); }\n" ++
  "    return e <= 1e-2;\n}\n" ++
  "void jacobi9(float Ain[9], out float w[3], out float V[9]) {\n" ++
  "    float A[9]; for (int i = 0; i < 9; i++) A[i] = Ain[i];\n" ++
  "    for (int i = 0; i < 9; i++) V[i] = (i%4==0)?1.0:0.0;\n" ++
  "    int pp[3]; pp[0]=0; pp[1]=0; pp[2]=1; int qq[3]; qq[0]=1; qq[1]=2; qq[2]=2;\n" ++
  "    for (int sweep = 0; sweep < 50; sweep++) {\n" ++
  "        if (abs(A[1])+abs(A[2])+abs(A[5]) < 1e-20) break;\n" ++
  "        for (int k = 0; k < 3; k++) {\n" ++
  "            int p = pp[k], q = qq[k]; float apq = A[p*3+q];\n" ++
  "            if (abs(apq) < 1e-20) continue;\n" ++
  "            float phi = 0.5*atan2(2.0*apq, A[q*3+q]-A[p*3+p]); float c = cos(phi), s = sin(phi);\n" ++
  "            for (int i = 0; i < 3; i++) { float aip=A[i*3+p], aiq=A[i*3+q]; A[i*3+p]=c*aip-s*aiq; A[i*3+q]=s*aip+c*aiq; }\n" ++
  "            for (int i = 0; i < 3; i++) { float api=A[p*3+i], aqi=A[q*3+i]; A[p*3+i]=c*api-s*aqi; A[q*3+i]=s*api+c*aqi; }\n" ++
  "            for (int i = 0; i < 3; i++) { float vip=V[i*3+p], viq=V[i*3+q]; V[i*3+p]=c*vip-s*viq; V[i*3+q]=s*vip+c*viq; }\n        }\n    }\n" ++
  "    w[0]=A[0]; w[1]=A[4]; w[2]=A[8];\n}\n" ++
  "void kabsch(float H[9], out float R[9]) {\n" ++
  "    float S[9]; for (int i = 0; i < 3; i++) for (int j = 0; j < 3; j++) S[i*3+j] = H[i]*H[j]+H[3+i]*H[3+j]+H[6+i]*H[6+j];\n" ++
  "    float w[3]; float Vc[9]; jacobi9(S,w,Vc);\n" ++
  "    int ord[3]; ord[0]=0; ord[1]=1; ord[2]=2;\n" ++
  "    for (int a = 0; a < 3; a++) for (int b = a+1; b < 3; b++) if (w[ord[b]] > w[ord[a]]) { int t=ord[a]; ord[a]=ord[b]; ord[b]=t; }\n" ++
  "    float V[9]; float sig[3];\n" ++
  "    for (int c = 0; c < 3; c++) { sig[c] = sqrt(max(w[ord[c]],0.0)); for (int r = 0; r < 3; r++) V[r*3+c] = Vc[r*3+ord[c]]; }\n" ++
  "    float U[9];\n" ++
  "    for (int c = 0; c < 3; c++) {\n" ++
  "        float3 hv = float3(H[0]*V[c]+H[1]*V[3+c]+H[2]*V[6+c], H[3]*V[c]+H[4]*V[3+c]+H[5]*V[6+c], H[6]*V[c]+H[7]*V[3+c]+H[8]*V[6+c]);\n" ++
  "        float sc = sig[c] > 1e-12 ? 1.0/sig[c] : 0.0; U[c]=hv.x*sc; U[3+c]=hv.y*sc; U[6+c]=hv.z*sc;\n    }\n" ++
  "    for (int c = 0; c < 3; c++) if (sig[c] <= 1e-12) {\n" ++
  "        int a = (c+1)%3, b = (c+2)%3; float3 ua = float3(U[a],U[3+a],U[6+a]), ub = float3(U[b],U[3+b],U[6+b]);\n" ++
  "        float3 uc = cr(ua,ub); U[c]=uc.x; U[3+c]=uc.y; U[6+c]=uc.z;\n    }\n" ++
  "    float Vt[9]; for (int i = 0; i < 3; i++) for (int j = 0; j < 3; j++) Vt[i*3+j] = V[j*3+i];\n" ++
  "    float UVt[9]; mul9(U,Vt,UVt); float sgn = det9(UVt) < 0 ? -1.0 : 1.0;\n" ++
  "    float Ud[9]; for (int i = 0; i < 9; i++) Ud[i] = U[i]; Ud[2]*=sgn; Ud[5]*=sgn; Ud[8]*=sgn;\n" ++
  "    mul9(Ud,Vt,R);\n}\n" ++
  "void finishAlign(float Hin[9], int N, float3 a0, float3 a1, float3 b0, float3 b1, out float R[9]) {\n" ++
  "    if (N == 1) { rodrigues(a0,b0,R); return; }\n" ++
  "    float H[9]; for (int i = 0; i < 9; i++) H[i] = Hin[i];\n" ++
  "    float3 ns = cr(a0,a1), nd = cr(b0,b1); float ln = length(ns), ld = length(nd);\n" ++
  "    if (ln > 1e-9 && ld > 1e-9) {\n" ++
  "        float vsa[3]; float3 vs = ns*(length(a0)/(ln+EPS)); vsa[0]=vs.x; vsa[1]=vs.y; vsa[2]=vs.z;\n" ++
  "        float vda[3]; float3 vd = nd*(length(b0)/(ld+EPS)); vda[0]=vd.x; vda[1]=vd.y; vda[2]=vd.z;\n" ++
  "        for (int i = 0; i < 3; i++) for (int j = 0; j < 3; j++) H[i*3+j] += vsa[i]*vda[j];\n    }\n" ++
  "    regularize(H); ns30(H,R); if (!valid9(R)) kabsch(H,R);\n}\n\n" ++
  "[shader(\"compute\")]\n[numthreads(1, 1, 1)]\n" ++
  "void skeleton_fit(uint3 tid : SV_DispatchThreadID)\n{\n" ++
  "    if (tid.x != 0) return;\n" ++
  "    uint J, st; parents.GetDimensions(J, st);\n" ++
  "    uint Vc, st2; v0.GetDimensions(Vc, st2); uint V = Vc/3;\n" ++
  "    for (uint j = 0; j < J; j++) for (int k = 0; k < 9; k++) { int r=k/3, c=k%3; outbw[j*16+r*4+c] = bw[j*16+r*4+c]; }\n" ++
  "    for (uint i = 1; i < J; i++) {\n" ++
  "        int p = parents[i];\n" ++
  "        int ch[32]; int nc = 0;\n" ++
  "        for (uint j = 0; j < J; j++) if (parents[j] == (int)i && (int)j != (int)i) { if (nc < 32) { ch[nc] = (int)j; nc++; } }\n" ++
  "        if (nc == 0) { for (int k = 0; k < 9; k++) { int r=k/3,c=k%3; outbw[i*16+r*4+c] = outbw[p*16+r*4+c]; } continue; }\n" ++
  "        float bpx = bw[i*16+3], bpy = bw[i*16+7], bpz = bw[i*16+11];\n" ++
  "        float3 jpi = float3(jpos[i*3], jpos[i*3+1], jpos[i*3+2]);\n" ++
  "        float Hs[9]; for (int k = 0; k < 9; k++) Hs[k] = 0;\n" ++
  "        int cnt = 0; float3 sa0=float3(0,0,0), sa1=float3(0,0,0), sb0=float3(0,0,0), sb1=float3(0,0,0);\n" ++
  "        for (uint v = 0; v < V; v++) {\n" ++
  "            if (sw[v*J+i] <= 0.01) continue;\n" ++
  "            float3 tg = float3(v0[v*3]-jpi.x, v0[v*3+1]-jpi.y, v0[v*3+2]-jpi.z);\n" ++
  "            float3 og = float3(bsh[v*3]-bpx, bsh[v*3+1]-bpy, bsh[v*3+2]-bpz);\n" ++
  "            float ta[3]={tg.x,tg.y,tg.z}; float oa[3]={og.x,og.y,og.z};\n" ++
  "            for (int a = 0; a < 3; a++) for (int b = 0; b < 3; b++) Hs[a*3+b] += ta[a]*oa[b];\n" ++
  "            if (cnt == 0) { sa0=tg; sb0=og; } else if (cnt == 1) { sa1=tg; sb1=og; } cnt++;\n        }\n" ++
  "        float Rinit[9]; finishAlign(Hs, cnt, sa0, sa1, sb0, sb1, Rinit);\n" ++
  "        float Hc[9]; for (int k = 0; k < 9; k++) Hc[k] = 0;\n" ++
  "        float3 ca0=float3(0,0,0), ca1=float3(0,0,0), cb0=float3(0,0,0), cb1=float3(0,0,0);\n" ++
  "        for (int c = 0; c < nc; c++) {\n" ++
  "            int cj = ch[c];\n" ++
  "            float3 wv = float3(bw[cj*16+3]-bpx, bw[cj*16+7]-bpy, bw[cj*16+11]-bpz);\n" ++
  "            float3 pco = float3(Rinit[0]*wv.x+Rinit[1]*wv.y+Rinit[2]*wv.z, Rinit[3]*wv.x+Rinit[4]*wv.y+Rinit[5]*wv.z, Rinit[6]*wv.x+Rinit[7]*wv.y+Rinit[8]*wv.z);\n" ++
  "            float3 pcn = float3(jpos[cj*3]-jpi.x, jpos[cj*3+1]-jpi.y, jpos[cj*3+2]-jpi.z);\n" ++
  "            float na[3]={pcn.x,pcn.y,pcn.z}; float oa[3]={pco.x,pco.y,pco.z};\n" ++
  "            for (int a = 0; a < 3; a++) for (int b = 0; b < 3; b++) Hc[a*3+b] += na[a]*oa[b];\n" ++
  "            if (c == 0) { ca0=pcn; cb0=pco; } else if (c == 1) { ca1=pcn; cb1=pco; }\n        }\n" ++
  "        float Arot[9]; finishAlign(Hc, nc, ca0, ca1, cb0, cb1, Arot);\n" ++
  "        float R0[9]; for (int k = 0; k < 9; k++) { int r=k/3,c=k%3; R0[k] = outbw[i*16+r*4+c]; }\n" ++
  "        float tmp[9]; mul9(Arot, Rinit, tmp); float Ri[9]; mul9(tmp, R0, Ri);\n" ++
  "        for (int k = 0; k < 9; k++) { int r=k/3,c=k%3; outbw[i*16+r*4+c] = Ri[k]; }\n    }\n" ++
  "    for (uint j = 0; j < J; j++) {\n" ++
  "        outbw[j*16+3] = jpos[j*3]; outbw[j*16+7] = jpos[j*3+1]; outbw[j*16+11] = jpos[j*3+2];\n" ++
  "        outbw[j*16+12]=0; outbw[j*16+13]=0; outbw[j*16+14]=0; outbw[j*16+15]=1;\n    }\n}\n"

/-- SE3 inverse of each bind world transform → inverse-bind: one thread per joint. -/
def se3Inverse (cfg : Config := {}) : String :=
  header ++
  "[[vk::binding(0, 0)]] StructuredBuffer<float>  bw;   // (J*16) bind world\n" ++
  "[[vk::binding(1, 0)]] RWStructuredBuffer<float> inv; // (J*16) inverse-bind\n\n" ++
  attr cfg "se3_inverse" ++
  "{\n" ++
  "    uint j = tid.x;\n" ++
  "    uint J, s; inv.GetDimensions(J, s); J /= 16;\n" ++
  "    if (j >= J) return;\n" ++
  "    uint o = j * 16;\n" ++
  "    float t[3] = {bw[o+3], bw[o+7], bw[o+11]};\n" ++
  "    for (int r = 0; r < 3; r++) {\n" ++
  "        for (int c = 0; c < 3; c++) inv[o+r*4+c] = bw[o+c*4+r];  // Rᵀ\n" ++
  "        inv[o+r*4+3] = -(bw[o+r] * t[0] + bw[o+4+r] * t[1] + bw[o+8+r] * t[2]);  // -Rᵀt\n    }\n" ++
  "    inv[o+12]=0; inv[o+13]=0; inv[o+14]=0; inv[o+15]=1;\n}\n"

/-- Sparse RBF joint regression Jpos = M · v0 (CSR): one thread per joint. -/
def rbf (cfg : Config := {}) : String :=
  header ++
  "[[vk::binding(0, 0)]] StructuredBuffer<float3> v0;    // (V)    rest verts\n" ++
  "[[vk::binding(1, 0)]] StructuredBuffer<uint>   crow;  // (J+1)  CSR row offsets\n" ++
  "[[vk::binding(2, 0)]] StructuredBuffer<uint>   col;   // (NNZ)  CSR columns\n" ++
  "[[vk::binding(3, 0)]] StructuredBuffer<float>  val;   // (NNZ)  CSR values\n" ++
  "[[vk::binding(4, 0)]] RWStructuredBuffer<float3> jpos; // (J)   output joint positions\n\n" ++
  attr cfg "rbf" ++
  "{\n" ++
  "    uint i = tid.x;\n" ++
  "    uint J, s; jpos.GetDimensions(J, s);\n" ++
  "    if (i >= J) return;\n" ++
  "    float3 acc = float3(0.0);\n" ++
  "    for (uint k = crow[i]; k < crow[i + 1]; ++k)\n" ++
  "        acc += val[k] * v0[col[k]];\n" ++
  "    jpos[i] = acc;\n" ++
  "}\n"

end Sinew.SlangCodegen.Pheno
